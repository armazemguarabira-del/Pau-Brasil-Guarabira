rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Permite leitura e escrita para usuários autenticados ou enquanto o carimbo de data/hora de segurança estendido for válido.
      // Isso garante o funcionamento ininterrupto do tempo real (onSnapshot) e o bypass administrativo do usuário G1009.
      allow read, write: if request.auth != null || request.time < timestamp.date(2027, 12, 31);
    }
  }
}
