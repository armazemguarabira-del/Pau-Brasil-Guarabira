rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global catch-all safety block: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Function helpers
    function isSignedIn() {
      return request.auth != null;
    }

    // Explicit Match Blocks for All Identified Collections
    
    match /usuarios/{userId} {
      allow read, write: if isSignedIn();
    }

    match /empresas/{empresaId} {
      allow read, write: if isSignedIn();
    }

    match /colaboradores/{colabId} {
      allow read, write: if isSignedIn();
    }

    match /repack/{docId} {
      allow read, write: if isSignedIn();
    }

    match /repack_validades/{docId} {
      allow read, write: if isSignedIn();
    }

    match /despejo/{docId} {
      allow read, write: if isSignedIn();
    }

    match /armazem/{docId} {
      allow read, write: if isSignedIn();
    }

    match /quebras/{docId} {
      allow read, write: if isSignedIn();
    }

    match /validades/{docId} {
      allow read, write: if isSignedIn();
    }

    match /blitz_refugo/{docId} {
      allow read, write: if isSignedIn();
    }

    match /tarefas/{docId} {
      allow read, write: if isSignedIn();
    }

    match /registros/{docId} {
      allow read, write: if isSignedIn();
    }

    match /repack_action_plans/{docId} {
      allow read, write: if isSignedIn();
    }

    match /repack_a3_boards/{docId} {
      allow read, write: if isSignedIn();
    }

    match /dpo_audits/{docId} {
      allow read, write: if isSignedIn();
    }

    match /acessos/{docId} {
      allow read, write: if isSignedIn();
    }
  }
}
